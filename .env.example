# midnite — environment variables (Phase 72 SSO go-live)
#
# Copy to `.env` (gitignored) and fill in real values, OR export these in your
# shell / deployment secrets. This file holds SECRET VALUES; the operator config
# (`.midnite/operator.json`) holds only the env-var *names* + client IDs.
# Never commit real secrets. Full runbook: docs/SSO.md.

# ── Auth secrets (gateway) ────────────────────────────────────────────────────
# Signing secret for the gateway's JWTs. Unset ⇒ JWT auth is OFF and every SSO
# sign-in 503s (SSO issues our JWTs). Use a long random string (32+ chars).
MIDNITE_JWT_SECRET=

# OAuth client secrets — the value the provider console gives you. The NAME of
# each var is referenced from `.midnite/operator.json` (`clientSecretEnv`); the
# secret itself lives only here / in your deployment secrets.
MIDNITE_GOOGLE_CLIENT_SECRET=
MIDNITE_GITHUB_CLIENT_SECRET=

# Master key that encrypts the single-use SSO OAuth state (and other at-rest
# secrets). 64 hex chars (32 bytes), e.g. `openssl rand -hex 32`. Unset ⇒ a
# degraded warn at boot; required for a real SSO deployment.
MIDNITE_SECRET_KEY=

# ── Operator config path (gateway) ────────────────────────────────────────────
# Override where the operator-owned auth config is read from. Unset ⇒ the default
# `.midnite/operator.json` (gitignored). Point it elsewhere for a hosted deploy.
MIDNITE_OPERATOR_CONFIG=

# ── Web build target (packages/web) ───────────────────────────────────────────
# `static` (default) → Next `output: 'export'` for desktop + a static host, with
# the BFF auth routes absent. `server` → drops the export so `/api/auth/*` cookie
# routes run — required for a hosted SSO sign-in.
MIDNITE_WEB_TARGET=static

# Gateway origin the web app (server target) calls for the SSO one-time-code
# exchange + API/WS. e.g. https://gateway.midnite.example.com
NEXT_PUBLIC_GATEWAY_URL=http://localhost:7777

# ── Admin console origin (gateway) ────────────────────────────────────────────
# The admin app (Phase 73 E) is a static export on its OWN origin that reads the
# gateway cross-origin with `credentials: 'include'` (SSO cookie + /admin/*).
# List its origin(s) here so the gateway adds them to the CORS + terminal-WS
# allow-list with credentials enabled. Comma-separate multiple. Loopback origins
# are always allowed, so this is only needed for a deployed admin console.
# e.g. https://admin.midnite.example.com
MIDNITE_ADMIN_ORIGIN=
