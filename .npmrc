# Native-module ABI isolation (see docs/NATIVE-MODULES.md).
#
# The desktop app electron-rebuilds better-sqlite3/node-pty for Electron's ABI
# (Electron 33 = ABI 130); the gateway needs the Node ABI (Node 22 = ABI 127).
# pnpm's side-effects cache shares native build output through the global store
# via hardlinks, so one Electron-ABI rebuild could poison every checkout and
# worktree on the machine — the recurring "ABI 130 vs 127" gateway crash.
#
# side-effects-cache=false  → never share native build artifacts through the store
# package-import-method=clone-or-copy → node_modules files never share inodes
#                             with the store (copy-on-write clone, else copy)
side-effects-cache=false
package-import-method=clone-or-copy
