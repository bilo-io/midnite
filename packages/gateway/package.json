{
  "name": "@midnite/gateway",
  "version": "0.1.3",
  "private": true,
  "description": "midnite gateway — Nest.js daemon (REST + WS) + SQLite store + scheduler + agent pool",
  "main": "dist/main.js",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "default": "./dist/main.js"
    },
    "./bootstrap": {
      "types": "./dist/bootstrap.d.ts",
      "default": "./dist/bootstrap.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.99.0",
    "@fastify/multipart": "^8.3.1",
    "@fastify/static": "^7.0.4",
    "@google/generative-ai": "^0.24.1",
    "@midnite/shared": "workspace:*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-fastify": "^10.4.15",
    "@nestjs/platform-ws": "^10.4.15",
    "@nestjs/websockets": "^10.4.15",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^3.6.0",
    "croner": "^9.0.0",
    "drizzle-orm": "^0.36.4",
    "fastify": "^4.28.1",
    "fflate": "^0.8.3",
    "html-to-text": "^10.0.0",
    "jsonwebtoken": "^9.0.3",
    "node-pty": "^1.0.0",
    "nodemailer": "^9.0.1",
    "openai": "^6.44.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "unpdf": "^1.6.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^8.0.1",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  }
}
