{
  "name": "@midnite/desktop",
  "version": "0.0.0",
  "private": true,
  "description": "midnite desktop app (Electron) — bundles the gateway + web UI to run locally",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc -b",
    "start": "electron .",
    "rebuild": "electron-rebuild",
    "stage": "node scripts/stage-gateway.mjs",
    "dist": "pnpm stage && electron-builder --mac --config electron-builder.yml",
    "package": "electron-builder --mac --config electron-builder.yml",
    "package:win": "electron-builder --win --config electron-builder.yml",
    "package:linux": "electron-builder --linux --config electron-builder.yml"
  },
  "dependencies": {
    "@midnite/gateway": "workspace:*",
    "@midnite/shared": "workspace:*"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/node": "^22.10.2",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.6.3"
  }
}
