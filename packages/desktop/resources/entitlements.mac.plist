<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Electron under the hardened runtime needs JIT + writable/executable memory
       for V8, and dyld env vars. Library validation is disabled because the
       bundled gateway loads native .node modules (better-sqlite3, node-pty) that
       are rebuilt for Electron's ABI and not signed by the same team. Required for
       notarization to pass while still launching. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
  <key>com.apple.security.cs.allow-dyld-environment-variables</key>
  <true/>
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
