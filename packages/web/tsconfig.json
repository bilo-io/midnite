{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
      "dom.iterable",
      "ES2022"
    ],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "noEmit": true,
    "composite": false,
    // The web app never emits declarations (next build owns the bundle). Leaving
    // the base config's `declaration` on makes `tsc --noEmit` do declaration-emit
    // checking, which throws TS2742 when a dep's realpath isn't portably nameable
    // (pnpm's .pnpm store layout on a fresh install). Turning it off is the fix.
    "declaration": false,
    "declarationMap": false,
    "incremental": true,
    "allowJs": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "next-env.d.ts",
    ".next-server/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next",
    "out",
    "storybook-static",
    // Build-tool config; importing vitest/config + the React plugin drags in
    // vitest's bundled vite (v7) types, which clash with the app's vite (v6).
    // vitest loads/validates this file at runtime — it doesn't need app tsc.
    "vitest.config.ts"
  ],
  "references": [
    {
      "path": "../shared"
    }
  ]
}
