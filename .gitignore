node_modules/
dist/
build/
.next/
out/
.moon/cache/
.moon/docker/
*.tsbuildinfo

# Desktop packaging artifacts: build-staging/ is the staged gateway + web export
# (scripts/stage-gateway.mjs), desktop-installers/ collects the built .dmg/.exe/
# .AppImage. Both are regenerated by the release workflow — never committed.
build-staging/
desktop-installers/

*.db
*.db-journal
*.db-shm
*.db-wal
*.db-shm.bak
*.sqlite
*.sqlite-journal

# Local gateway data dir (SQLite DB, WAL, uploads, ad-hoc backups) — never committed
.midnite/*
# Same dir when the gateway runs from its own package (nested runtime data:
# its SQLite DB + timestamped backups + uploads/approvals) — never committed.
packages/gateway/.midnite/
# Phase 72: the operator config itself stays private, but its redaction-safe
# sample is committed so operators have a template.
!.midnite/operator.example.json

.env
.env.*
!.env.example

.DS_Store
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# Storybook
storybook-static/
*storybook.log

# Git worktrees: parallel-agent checkouts live in the repo-root .worktrees/ dir (never committed)
.worktrees/

# Claude Code: machine-local settings + agent worktrees (never committed)
.claude/settings.local.json
.claude/worktrees/
.claude/scheduled_tasks.lock
.vercel
